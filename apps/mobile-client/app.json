{
  "expo": {
    "name": "Kbouffe",
    "slug": "kbouffe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kbouffe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kbouffe.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f97316",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kbouffe.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B2B",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f97316",
          "dark": {
            "backgroundColor": "#0f172a"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "KBouffe utilise votre position pour trouver les restaurants proches et calculer la livraison.",
          "locationWhenInUsePermission": "KBouffe utilise votre position pour trouver les restaurants proches et calculer la livraison."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "29feeab5-e1c9-403b-9665-4bd22de42d2a"
      }
    },
    "owner": "dreamsevo"
  }
}
