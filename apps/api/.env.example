# =============================================
# SUPABASE — Obligatoire
# Récupérer ces valeurs dans :
# Supabase Dashboard → Settings → API
# =============================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================
# CLOUDFLARE (optionnel, pour les Workers)
# =============================================
# Ces variables sont automatiquement injectées par Wrangler
# CF_ACCOUNT_ID=your_cloudflare_account_id

# =============================================
# PAIEMENTS MTN MOBILE MONEY (optionnel)
# =============================================
# MTN_API_KEY=your_mtn_api_key
# MTN_API_SECRET=your_mtn_api_secret
# MTN_COLLECTION_SUBSCRIPTION_KEY=your_subscription_key
# MTN_ENVIRONMENT=sandbox

# =============================================
# SMS (optionnel)
# =============================================
# SMS_API_KEY=your_sms_api_key
# SMS_SENDER_ID=KBOUFFE
