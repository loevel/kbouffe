{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
  "remoteCache": {
    "enabled": true,
    "teamId": "${TURBO_TEAM}",
    "apiUrl": "https://api.turborepo.com"
  },
  "tasks": {
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [
        "coverage/**",
        "**/coverage/**"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "apps/*/.next/**",
        "apps/*/.open-next/**",
        "apps/*/dist/**",
        "packages/*/dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
